---
import HomeHero from "../components/home/HomeHero.astro";
import HomeLayout from "../layouts/HomeLayout.astro";
import starSmallRaw from "../assets/home/star-small.svg?raw";

const COLORS = ["#00938A", "#826887", "#F7ADC5", "#F7CB1B"];

const FONT_CLASS: Record<string, string> = {
  michroma: "font-[Michroma]",
  cute: "font-[CuteFont]",
};

const links = [
  { title: "Warsztaty\n25.10", font: "cute",    fontSize: "clamp(20px, 2.1vw, 68px)", x: "18vw", y: "52vh" },
  { title: "Plener\nlipiec",   font: "michroma", fontSize: "clamp(15px, 1.6vw, 51px)", x: "82vw", y: "38vh" },
];

const stars = links.map((link) => {
  const color = COLORS[Math.floor(Math.random() * COLORS.length)];
  const svg = starSmallRaw
    .replace(/fill="#[A-Fa-f0-9]{6}"/, `fill="${color}"`)
    .replace(/width="\d+"/, 'width="100%"')
    .replace(/height="\d+"/, 'height="100%"');
  return { ...link, svg, color };
});
---

<HomeLayout
  title="Fundacja Działo Sztuki | Warsztaty i Integracje Firmowe Łódź"
  description="Fundacja Działo Sztuki – warsztaty artystyczne, integracje firmowe i arteterapia w Łodzi. Towarzyszymy w odkrywaniu sztuki dzieciom, młodzieży i dorosłym."
>
  {
    stars.map((star, i) => (
      <a
        href={star.path ?? "#"}
        data-color={star.color}
        class="star-fade fixed inline-block no-underline z-10"
        style={`left:${star.x};top:${star.y};transform:translate(-50%,-50%);animation-delay:${i * 0.8}s;width:clamp(130px,12vw,380px);`}
      >
        <Fragment set:html={star.svg} />
        <span
          class={`${FONT_CLASS[star.font]} absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-black text-center w-3/4 whitespace-pre-line`}
          style={`font-size:${star.fontSize};line-height:1.1;`}
        >
          {star.title}
        </span>
      </a>
    ))
  }
  <HomeHero />
</HomeLayout>

<script>
  function setupStarFade() {
    document.querySelectorAll<HTMLElement>(".star-fade").forEach((star) => {
      const hex = star.dataset.color ?? "#000000";
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      const glow = `drop-shadow(0 0 8px rgba(${r},${g},${b},0.5))`;

      star.addEventListener("mouseenter", () => {
        star.style.transform = "translate(-50%,-50%) scale(1.08)";
        star.style.filter = glow;
      });
      star.addEventListener("mouseleave", () => {
        star.style.transform = "translate(-50%,-50%)";
        star.style.filter = "";
      });
    });
  }

  setupStarFade();
  document.addEventListener("astro:page-load", setupStarFade);
</script>

<style>
  @keyframes starFadeIn {
    to { opacity: 1; }
  }
  .star-fade {
    opacity: 0;
    animation: starFadeIn 1s ease forwards;
    transition: transform 0.3s ease, filter 0.3s ease;
  }
</style>
