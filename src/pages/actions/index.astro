---
import PageLayout from "../../layouts/PageLayout.astro";
---

<PageLayout>
  <div
    id="plant-scroll"
    style="height: 500vh; position: relative;"
  >
    <div
      id="plant-sticky"
      style="position: sticky; top: 80px; height: calc(100vh - 80px); overflow: hidden;"
    >
      <!-- SVG injected by script after fetch -->
    </div>
  </div>
</PageLayout>

<style>
  #plant-sticky {
    contain: layout style paint;
  }
  #plant-sticky svg {
    width: 100%;
    height: auto;
    display: block;
    will-change: transform;
  }
</style>

<script>
  import { initPlantAnimation, restoreScroll } from "../../scripts/plantAnimation";

  async function setup() {
    const container = document.getElementById("plant-sticky");
    if (!container) return;

    if (!container.querySelector("svg")) {
      const res = await fetch("/full-plant.svg");
      container.innerHTML = await res.text();
    }

    initPlantAnimation();

    // Restore scroll position when returning from a flower page
    const savedY = sessionStorage.getItem("plantScrollY");
    if (savedY) {
      sessionStorage.removeItem("plantScrollY");
      requestAnimationFrame(() => restoreScroll(parseFloat(savedY)));
    }
  }

  document.addEventListener("astro:page-load", setup);
</script>
