---
interface Props {
  href?: string;
  target?: string;
  class?: string;
  size?: "md";
}

const { href, target, class: className, size = "md" } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  target={target}
  class:list={[
    "btn",
    size === "md" && "btn-md",
    className,
  ]}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #f7adc5;
    font-family: "CuteFont", cursive;
    cursor: pointer;
    text-decoration: none;
    border: none;
    white-space: nowrap;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .btn:hover {
    transform: scale(1.02);
    opacity: 0.85;
  }

  .btn:active {
    opacity: 0.7;
    transition-duration: 0.05s;
  }

  .btn-md {
    height: 65px;
    padding-left: 1.75rem; /* px-7 = 28px */
    padding-right: 1.75rem;
    padding-top: 0.5rem;   /* py-2 = 8px */
    padding-bottom: 0.5rem;
    font-size: 40px;
    line-height: 1;
  }
</style>
