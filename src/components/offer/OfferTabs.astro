---
import IntegracjeContent from "./IntegracjeContent.astro";
import WarsztatyContent from "./WarsztatyContent.astro";
import PolkolonieContent from "./PolkolonieContent.astro";

const tabs = [
  { id: "integracje", label: "INTEGRACJE" },
  { id: "warsztaty", label: "WARSZTATY" },
  { id: "polkolonie", label: "PÓŁKOLONIE" },
];
---

<script>
  const buttons = document.querySelectorAll<HTMLElement>("[data-tab]");
  const panels = document.querySelectorAll<HTMLElement>("[data-panel]");

  const FADE = 200;
  let switching = false;
  let firstRun = true;

  function activate(id: string) {
    buttons.forEach((btn) => {
      btn.dataset.active = btn.dataset.tab === id ? "true" : "false";
    });

    if (firstRun) {
      panels.forEach((panel) => {
        const active = panel.dataset.panel === id;
        panel.style.display = active ? "block" : "none";
        panel.style.opacity = active ? "1" : "0";
        panel.style.pointerEvents = active ? "auto" : "none";
      });
      firstRun = false;
      return;
    }

    const current = Array.from(panels).find(
      (p) => p.style.display !== "none" && p.dataset.panel !== id,
    );
    const next = document.querySelector<HTMLElement>(`[data-panel="${id}"]`);

    if (!next) return;

    if (current && current !== next && !switching) {
      switching = true;
      current.style.opacity = "0";
      current.style.pointerEvents = "none";

      setTimeout(() => {
        current.style.display = "none";
        next.style.display = "block";
        next.style.opacity = "0";
        next.style.pointerEvents = "auto";

        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            next.style.opacity = "1";
            setTimeout(() => {
              switching = false;
            }, FADE);
          }),
        );
      }, FADE);
    } else if (!switching) {
      next.style.display = "block";
      next.style.opacity = "1";
      next.style.pointerEvents = "auto";
    }
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      window.location.hash = btn.dataset.tab!;
    });
  });

  function activateFromHash() {
    const hash = window.location.hash.slice(1);
    const valid = Array.from(buttons).some((b) => b.dataset.tab === hash);
    activate(valid ? hash : "integracje");
  }

  window.addEventListener("hashchange", activateFromHash);
  activateFromHash();
</script>

<div class="mx-40 mt-24 mb-5">
  <div class="w-full">
    <div
      class="bg-black w-full h-16.75 justify-center flex items-center px-27 gap-x-24"
    >
      {
        tabs.map((tab) => (
          <button
            data-tab={tab.id}
            data-active={tab.id === "integracje" ? "true" : "false"}
            class="tab-btn font-[Michroma] uppercase tracking-widest transition-colors duration-200 cursor-pointer"
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <div class="tab-panels border border-black pt-15 px-13.5 pb-6.5">
      {
        tabs.map((tab) => (
          <div
            data-panel={tab.id}
            class="tab-panel"
            style={`display: ${tab.id === "integracje" ? "block" : "none"}; opacity: ${tab.id === "integracje" ? "1" : "0"}; pointer-events: ${tab.id === "integracje" ? "auto" : "none"};`}
          >
            {tab.id === "integracje" && <IntegracjeContent />}
            {tab.id === "warsztaty" && <WarsztatyContent />}
            {tab.id === "polkolonie" && <PolkolonieContent />}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .tab-panels {
  }
  .tab-panel {
    transition: opacity 0.2s ease;
  }
  .tab-btn {
    font-size: 16px;
    color: #f5f5f5;
  }
  .tab-btn[data-active="true"] {
    color: #f7cb1b;
  }
</style>
