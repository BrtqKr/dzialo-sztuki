import mask3 from "../../assets/about/authors/mask3.svg";
import mask4 from "../../assets/about/authors/mask4.svg";
import AuthorCard from "./AuthorCard.astro";

const authors = [
  {
    photo: author1.src,
    mask: mask1.src,
    maskW: 551,
    maskH: 552,
    name: "Dominika Gruszczyńska",
    title: "Prezeska Fundacji Działo Sztuki",
    gapClass: "pl-16 pt-8 pr-8",
    desc: "Z wykształcenia jestem magistrą kierunku Art & Design na UKEN. Zarówno moja praca licencjacka, jak i magisterska były projektami gier komputerowych, oraz ilustrowanych książek dla dzieci. Ukończyłam również Liceum Plastyczne im. Szermentowskiego na kierunku tradycyjnych technik malarskich i pozłotniczych. Na co dzień pracuję jako metodyk i nauczyciel - lubię wspierać innych w rozwoju i tworzyć przestrzeń, w której każdy może czuć się swobodnie. Mam doświadczenie w pracy z ludźmi w różnym wieku :o). Prywatnie jestem gamerem, który uwielbia filmy, seriale, kolekcjonowanie różnych pierdół i rysowanie. Mam również 9-letniego mopsa o imieniu Donatello, który jest dla mnie całym światem! :o) Moją życiową misją jest sprawienie, aby ludzie czuli się wyjątkowi, zauważeni i zaopiekowani.",
  },
  {
    photo: author2.src,
    mask: mask2.src,
    maskW: 420,
    maskH: 520,
    name: "Alicja Pawluk-Chocholska",
    title: "Wiceprezeska Fundacji Działo Sztuki",
    gapClass: "pl-8 pr-3.5 pb-8",
    desc: "Słowa klucz o mnie: pedagożka, arteterapeutka, artystka i siostra. W 2023 roku ukończyłam Edukację artystyczną w zakresie sztuk plastycznych oraz arteterapię w Instytucie Edukacji Artystycznej na Akademii Pedagogiki Specjalnej w Warszawie. Dyplomy zrealizowałam w pracowni grafiki warsztatowej, opowiadając o moich osobistych doświadczeniach jako kobiety, córki i siostry. W sztuce najbardziej interesuje mnie jej terapeutyczna moc, dlatego tworzę programy, w których staje się ona narzędziem do odkrywania siebie i sposobem komunikacji z sobą oraz ze światem. Jako terapeutka pracowałam w warsztatach terapii zajęciowej oraz w szpitalach na oddziałach psychiatrycznych, wspierając osoby z niepełnosprawnością intelektualną i osoby w kryzysie psychicznym. Od 2021 roku uczę rysunku i prowadzę zajęcia dla uczniów szkoły podstawowej, a od 2023 roku mam pod opieką zespół nauczycieli, z którymi pracuje rozwojowo. W swoich działaniach kieruję się uważnością, ciekawością i autentycznym zainteresowaniem drugim człowiekiem.",
  },
  {
    photo: author3.src,
    mask: mask3.src,
    maskW: 551,
    maskH: 552,
    name: "Aleksandra Rosochacka",
    gapClass: "pl-6",
    desc: "Jestem twórczynią wszechstronną i łączę w swojej pracy zarówno narzędzia tradycyjne, jak i nowe media cyfrowe. Szczególnie dobrze rozumiem się z litografią, ołówkiem, akwarelą, gwaszem, i grafiką komputerową. Te media są dla mnie językiem, dzięki któremu mogę komunikować się jako twórca i nauczyciel, pokazywać innym rzeczy, które wydają się być niedostępne, ukryte lub są alternatywnymi drogami wyrazu i docierania do siebie samego. Posiadam doświadczenie dydaktyczne w nauczaniu dzieci, młodzieży i dorosłych w zakresie sztuki arteterapii i metodyki. Interesuje się pojęciem pamięci i czasu oraz zgłębianiem tematu znaczenia sztuki jako narzędzia terapeutycznego w samorozwoju oraz relacji człowieka z naturą, korzystając ze swojego rodzinnego doświadczenia oraz życia pośród ludzi i zwierząt. Zajmuję się też szerokim wachlarzem realizacji z dziedziny grafiki wydawniczej, identyfikacji wizualnej oraz projektowaniem graficznym. Ukończyłam edukację artystyczną w zakresie sztuk plastycznych oraz obroniłam dyplom z litografii na Uniwersytecie Marii Curie Skłodowskiej w Lublinie.",
  },
  {
    photo: author4.src,
    mask: mask4.src,
    maskW: 551,
    maskH: 620,
    name: "Katarzyna Zaremba",
    gapClass: "pl-10 pr-0",
    desc: `A ja, krążę między tworzeniem a pokazywaniem - odnajduję się w obu tych przestrzeniach równie naturalnie. Pracuję solo, ale też w dwójkach, w trójkach, piątkach i dziesiątkach - lubię zmieniać perspektywę i dynamikę działania.<br><br>Tworzę na styku malarstwa i fotografii, łącząc je intuicyjnie i bez sztywnych podziałów. Interesują mnie napięcia, błędy i momenty, które wymykają się jednoznacznej interpretacji. Wychodzę od codzienności, rzeczy pozornie zwykłych. Prowadzę warsztaty i projekty, współtworzę wystawy — działam zarówno od strony koncepcji, jak i realizacji. Doceniam proces, wymianę i sytuacje, w których bardziej od dzieła liczy się działanie.<br><br>Ukończyłam malarstwo na Akademii Sztuk Pięknych w Łodzi.`,
  },
];
---

<div style="clip-path: inset(0 -100vw -100vh 0)">
  <section id="authors-section" class="py-12 md:py-24 w-full px-5 md:px-24">
    <div
      class="flex flex-col items-center w-full max-w-350 mx-auto gap-y-10 md:gap-y-16"
    >
      {
        (() => {
          const borderProps = [
            { borderColor: "#F7CB1B" },
            {
              borderColor: "#F7ADC5",
              borderTop: "-100vh",
              borderLeft: "0",
              borderRight: "-32px",
              borderSides: "left-bottom" as const,
            },
            {
              borderColor: "#816786",
              borderTop: "-100vh",
              borderRight: "-32px",
              borderSides: "right-bottom" as const,
              leftStubPx: 40,
            },
            {
              borderColor: "#00938A",
              borderTop: "-15rem",
              borderLeft: "0",
              borderRight: "-32px",
              borderSides: "no-top" as const,
              borderRightTop: "-4rem",
            },
          ];
          return authors.map((author, i) => (
            <AuthorCard {...author} {...borderProps[i]} index={i} />
          ));
        })()
      }
    </div>
  </section>
</div>

<script>
  function lerp(a: number, b: number, t: number) {
    return a + (b - a) * t;
  }
  function easeOut(t: number) {
    return 1 - Math.pow(1 - t, 3);
  }
  function getProgress(el: HTMLElement, startFrac = 1.0, endFrac = 0.2) {
    const rect = el.getBoundingClientRect();
    const start = window.innerHeight * startFrac;
    const end = window.innerHeight * endFrac;
    return Math.min(1, Math.max(0, (start - rect.top) / (start - end)));
  }

  function initAuthorsAnimation() {
    // Skip scroll animation on mobile — CSS handles stacked layout, no translateX needed
    if (window.innerWidth < 768) return;

    const OFFSET = 280;
    const LAG = 0.07;
    const SETTLE = 0.1;

    const rows = document.querySelectorAll<HTMLElement>("[data-author-index]");
    if (!rows.length) return;

    const state = Array.from(rows).map((row, i) => {
      const photoLeft = i % 2 === 0;
      const photo = row.querySelector<HTMLElement>(".author-photo")!;
      const text = row.querySelector<HTMLElement>(".author-text")!;
      const bordersEls = Array.from(
        row.querySelectorAll<HTMLElement>(".author-border"),
      );
      const photoDir = photoLeft ? -1 : 1;
      const textDir = photoLeft ? 1 : -1;
      photo.style.transform = `translateX(${photoDir * OFFSET}px)`;
      text.style.transform = `translateX(${textDir * OFFSET}px)`;
      for (const b of bordersEls)
        b.style.transform = `translateX(${textDir * OFFSET}px)`;
      return {
        row,
        photo,
        text,
        bordersEls,
        photoDir,
        textDir,
        photoX: photoDir * OFFSET,
        textX: textDir * OFFSET,
      };
    });

    let rafId = 0;

    function animate() {
      rafId = 0;
      let stillMoving = false;

      for (const s of state) {
        const p = easeOut(getProgress(s.row));
        const targetPhoto = lerp(s.photoDir * OFFSET, 0, p);
        const targetText = lerp(s.textDir * OFFSET, 0, p);
        s.photoX = lerp(s.photoX, targetPhoto, LAG);
        s.textX = lerp(s.textX, targetText, LAG);
        s.photo.style.transform = `translateX(${s.photoX}px)`;
        s.text.style.transform = `translateX(${s.textX}px)`;
        for (const b of s.bordersEls)
          b.style.transform = `translateX(${s.textX}px)`;

        if (
          Math.abs(s.photoX - targetPhoto) > SETTLE ||
          Math.abs(s.textX - targetText) > SETTLE
        ) {
          stillMoving = true;
        }
      }

      if (stillMoving) rafId = requestAnimationFrame(animate);
    }

    function scheduleAnimate() {
      if (!rafId) rafId = requestAnimationFrame(animate);
    }

    window.addEventListener("scroll", scheduleAnimate, { passive: true });
    scheduleAnimate();

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", scheduleAnimate);
        if (rafId) {
          cancelAnimationFrame(rafId);
          rafId = 0;
        }
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initAuthorsAnimation);
</script>
