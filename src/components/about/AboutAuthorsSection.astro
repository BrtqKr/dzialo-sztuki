---
import author1 from "../../assets/about/authors/author1.png";
import author2 from "../../assets/about/authors/author2.png";
import mask2 from "../../assets/about/authors/mask2.svg?raw";
---

<div style="clip-path: inset(0 -100vw -100vh 0)">
  <section id="authors-section" class="pt-24 pb-0 w-full">
    <div class="flex flex-row items-center justify-center w-full">
      <div id="author1-img" class="flex-shrink-0">
        <img src={author1.src} alt="Author" class="max-w-[420px]" />
      </div>

      <div class="relative flex-shrink-0 -ml-22">
        <div id="author1-container" class="pointer-events-none">
          <svg
            viewBox="0 0 465 340"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-[520px] h-auto block"
          >
            <path
              d="M1.03711 104.392L8.08606 1H463.037V339H95.0231L8.08606 191.088L65.0651 146.568L1.03711 104.392Z"
              stroke="#00938A"
              stroke-width="2"></path>
          </svg>
        </div>
        <div
          id="author1-text"
          class="absolute inset-0 z-10 pr-10 py-10 font-[Michroma] text-base leading-7"
        >
          <div class="shape-left"></div>
          <p>Linia pierwsza tekstu o autorze</p>
          <p>Linia druga tekstu o autorze</p>
          <p>Linia trzecia tekstu o autorze</p>
          <p>Linia czwarta tekstu o autorze</p>
          <p>Linia piata tekstu o autorze</p>
          <p>Linia szosta tekstu o autorze</p>
        </div>
      </div>
    </div>
  </section>
</div>

<!-- Author 2 -->
<section id="author2-section" class="pt-0 pb-24 w-full overflow-hidden">
  <div class="flex flex-row items-center justify-end pr-24 w-full gap-x-16">
    <!-- Name + title slide in from the left -->
    <div class="flex flex-col gap-y-3 font-[Michroma] text-right">
      <p id="author2-name" class="text-3xl">Imię Nazwisko</p>
      <p id="author2-title" class="text-lg text-[#00938A]">Tytuł / Rola</p>
    </div>

    <!-- Author photo with mask -->
    <div class="flex-shrink-0 relative" style="width: 400px;">
      <svg
        width="0"
        height="0"
        style="position:absolute"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <clipPath id="mask2-clip" clipPathUnits="objectBoundingBox">
            <path
              transform="scale(0.002525252525, 0.001872659176)"
              d="M184.489 0L131.379 184.268L0 163.793L109.016 294.577L26.5553 331.347L157.934 406.977L250.179 534L285.12 381.07L396 416.169L367.115 248.615L396 119.92L264.621 184.268L184.489 0Z"
            ></path>
          </clipPath>
        </defs>
      </svg>
      <img
        src={author2.src}
        alt="Author 2"
        class="w-full h-auto block"
        style="clip-path: url(#mask2-clip);"
      />
    </div>
  </div>
</section>

<style>
  .shape-left {
    float: left;
    width: 112px;
    height: 230px;
    shape-outside: polygon(
      0px 0px,
      30px 0px,
      30px 36px,
      20px 36px,
      95px 67px,
      30px 99px,
      120px 230px,
      0px 230px
    );
  }
</style>

<script>
  // ── Author 1 animation ──────────────────────────────────────────
  const section = document.getElementById("authors-section")!;
  const authorEl = document.getElementById("author1-img") as HTMLElement;
  const textEl = document.getElementById("author1-text") as HTMLElement;
  const containerEl = document.getElementById(
    "author1-container",
  ) as HTMLElement;

  const OFFSET = 280;
  const TEXT_LAG = 0.07;
  const CONTAINER_LAG = 0.04;

  let textX = OFFSET;
  let containerX = OFFSET + 200;

  function lerp(a: number, b: number, t: number) {
    return a + (b - a) * t;
  }

  function getProgress() {
    const rect = section.getBoundingClientRect();
    const start = window.innerHeight * 1.0;
    const end = window.innerHeight * 0.05;
    return Math.min(1, Math.max(0, (start - rect.top) / (start - end)));
  }

  function easeOut(t: number) {
    return 1 - Math.pow(1 - t, 3);
  }

  function animate() {
    const progress = easeOut(getProgress());
    const targetAuthorX = lerp(-OFFSET, 0, progress);
    const targetTextX = lerp(OFFSET, 0, progress);

    textX = lerp(textX, targetTextX, TEXT_LAG);
    containerX = lerp(containerX, textX, CONTAINER_LAG);

    authorEl.style.transform = `translateX(${targetAuthorX}px)`;
    textEl.style.transform = `translateX(${textX}px)`;
    containerEl.style.transform = `translateX(${containerX}px)`;

    requestAnimationFrame(animate);
  }

  containerEl.style.transform = `translateX(${OFFSET + 200}px)`;
  authorEl.style.transform = `translateX(${-OFFSET}px)`;
  textEl.style.transform = `translateX(${textX}px)`;

  requestAnimationFrame(animate);

  // ── Author 2 animation ──────────────────────────────────────────
  const author2Section = document.getElementById("author2-section")!;
  const nameEl = document.getElementById("author2-name") as HTMLElement;
  const titleEl = document.getElementById("author2-title") as HTMLElement;

  const SLIDE_OFFSET = 120;
  const NAME_LAG = 0.1;

  let nameX = -SLIDE_OFFSET;

  function getAuthor2Progress() {
    const rect = author2Section.getBoundingClientRect();
    const start = window.innerHeight * 0.95;
    const end = window.innerHeight * 0.35;
    return Math.min(1, Math.max(0, (start - rect.top) / (start - end)));
  }

  function animateAuthor2() {
    const nameTarget = lerp(-SLIDE_OFFSET, 0, easeOut(getAuthor2Progress()));
    nameX = lerp(nameX, nameTarget, NAME_LAG);
    nameEl.style.transform = `translateX(${nameX}px)`;
    requestAnimationFrame(animateAuthor2);
  }

  nameEl.style.transform = `translateX(${-SLIDE_OFFSET}px)`;

  requestAnimationFrame(animateAuthor2);
</script>
